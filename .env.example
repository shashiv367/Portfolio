# Frontend (Vite) — leave empty in dev to use Vite proxy (/api → localhost:5000)
VITE_API_URL=

# Backend API
PORT=5000
CLIENT_URL=http://localhost:5173,http://localhost:4173

# Firebase Firestore
FIREBASE_SERVICE_ACCOUNT_PATH=./server/firebase-service-account.json

# EmailJS (connect Gmail inside EmailJS.com — no app password in this repo)
# Required: EmailJS dashboard → Account → Security → enable
# "Allow API requests from non-browser applications" (server sends mail via API)
# https://www.emailjs.com/docs/
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
EMAILJS_TEMPLATE_OWNER=your_owner_template_id
EMAILJS_TEMPLATE_USER=your_user_template_id
OWNER_EMAIL=you@example.com
